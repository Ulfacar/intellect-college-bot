# STAGING 1 — пример server env. СКОПИРУЙ на VPS в /etc/intellect/staging.env, заполни
# реальными значениями, chmod 600, владелец root/deploy-user. РЕАЛЬНЫЙ ФАЙЛ В GIT НЕ КОММИТИМ.
# Значения ниже — плейсхолдеры (`__...__`) и безопасные примеры, без секретов.
#
# Один файл — источник истины и для приложения (env_file в compose), и для compose-level
# параметров Caddy/домена. deploy.sh делает `set -a; . /etc/intellect/staging.env; set +a`
# перед `docker compose up`, поэтому и ${STAGING_DOMAIN}, и app-переменные берутся отсюда.

# --- окружение / фичефлаги (owner §5) ---
ENVIRONMENT=staging          # ВАЖНО: код читает ENVIRONMENT, не APP_ENV
ADMIN_UI_V2=true
DEMO_LOGIN=false

# --- персистентные бэкенды (НЕ memory/stub — иначе fail-fast на старте) ---
PANEL_BACKEND=postgres       # управляет и панелью диалогов, и leadstore (сессии/лиды)
CRM_BACKEND=postgres         # локальный слой Postgres, без внешнего CRM для Telegram-пилота
STATE_BACKEND=redis          # диалоговый state переживает рестарт (Redis AOF)

# --- хранилища ---
# имя пользователя/БД фиксированы в docker-compose.staging.yml (college / college_staging)
POSTGRES_PASSWORD=__DB_PASSWORD__
DATABASE_URL=postgresql+asyncpg://college:__DB_PASSWORD__@db:5432/college_staging
REDIS_URL=redis://redis:6379/0

# --- админка (только нормальная авторизация; сильные секреты, иначе fail-fast) ---
ADMIN_USER=admin
ADMIN_PASSWORD=__STRONG_ADMIN_PASSWORD__
SESSION_SECRET=__RANDOM_64_HEX__          # openssl rand -hex 32  (>= 32 символов)
# MANAGERS=[{"login":"support1","name":"Саппорт 1","password":"__PW__"}]

# --- OpenRouter (owner §9) ---
OPENROUTER_API_KEY=__OPENROUTER_KEY__
LLM_MODEL_MAIN=anthropic/claude-haiku-4.5   # подтвердить slug в каталоге OpenRouter
LLM_DAILY_BUDGET_USD=2
LLM_MONTHLY_BUDGET_USD=20

# --- Telegram: ДВА тестовых бота (owner §8) ---
# У каждого свой token и webhook_secret. При заданных per-bot webhook_secret глобальный
# WEBHOOK_SECRET НЕ требуется: multi-bot маршрут /webhook/telegram/{bot_id} проверяет
# per-bot секрет, а одиночный /webhook/telegram неактивен без TELEGRAM_BOT_TOKEN.
TELEGRAM_BOTS=[{"id":"college_test_1","scenario":"admission","title":"Колледж (тест 1)","token":"__TOKEN_1__","webhook_secret":"__SECRET_1__"},{"id":"college_test_2","scenario":"admission","title":"Колледж (тест 2)","token":"__TOKEN_2__","webhook_secret":"__SECRET_2__"}]
TELEGRAM_ALLOWED_USER_IDS=__OWNER_TG_ID__   # старт smoke: только владелец; позже — id саппортов
TELEGRAM_FEEDBACK_ENABLED=true
# WEBHOOK_SECRET=                              # опционально; не требуется при per-bot секретах

# --- Caddy / домен / DuckDNS (compose-level параметры) ---
STAGING_DOMAIN=intellect-pilot.duckdns.org  # владелец подтвердит имя перед настройкой DNS
ACME_EMAIL=__ACME_EMAIL__
ADMIN_BASIC_USER=support
# bcrypt-хеш пароля для Caddy basic-auth перед /admin*:
#   docker run --rm caddy:2.11.4 caddy hash-password --plaintext 'ВАШ_ПАРОЛЬ'
# ВАЖНО: экранируй каждый '$' в хеше как '$$' (иначе docker compose примет сегменты
# хеша за переменные). Пример: $2a$14$abc...  ->  $$2a$$14$$abc...
ADMIN_BASIC_HASH=__CADDY_BCRYPT_HASH_ESCAPED__
DUCKDNS_SUBDOMAIN=intellect-pilot           # для scripts/duckdns_update.sh (token — в отдельном файле)
