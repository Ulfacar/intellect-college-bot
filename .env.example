# Скопируй в .env и заполни. Реальные секреты в git НЕ коммитим.

# --- OpenRouter (мозг бота) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Intellect College Bot
OPENROUTER_TIMEOUT_SECONDS=60
# Модель — уточнить у Emir (у него уже был обкатанный аналог). Заполнить перед продом.
LLM_MODEL_MAIN=
LLM_MODEL_CHEAP=

# --- WhatsApp-провайдер (НАШИ креды, не переиспользуем чужие!) ---
# Провайдер уточняется (wappi pro или другой). Базовый URL/токен/profile_id — свои.
WAPPI_BASE_URL=https://wappi.pro
WAPPI_TOKEN=
WAPPI_PROFILE_ID=
# 3 бота = 3 номера, один мозг. У каждого свой profile_id, сценарий один (admission).
# Вебхук входящих: в кабинете провайдера указать → https://<домен>/webhook/wappi
# BOTS=[{"id":"college_1","scenario":"admission","title":"Intellect 1","wappi_profile_id":""},{"id":"college_2","scenario":"admission","title":"Intellect 2","wappi_profile_id":""},{"id":"college_3","scenario":"admission","title":"Intellect 3","wappi_profile_id":""}]
WEBHOOK_SECRET=

# --- Хранилище ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/college
REDIS_URL=redis://localhost:6379/0
STATE_BACKEND=memory        # memory (дев) | redis (прод: диалоги переживают рестарт)
STATE_TTL_SECONDS=604800    # TTL неактивного диалога (7 дней)
POSTGRES_PASSWORD=postgres

# --- CRM / канбан колледжа (админка Emir через вебхуки) ---
# stub (память, MVP) | postgres (локальный слой) | college_admin (вебхуки админки — Фаза 2)
CRM_BACKEND=stub
# Референс вебхуков даст Emir (репо его админки). Заполнить при интеграции.
COLLEGE_ADMIN_WEBHOOK_URL=
COLLEGE_ADMIN_API_KEY=

# --- Админ-панель (канбан + чат + перехват) ---
PANEL_BACKEND=memory
ADMIN_ENABLED=true
ADMIN_USER=admin
ADMIN_PASSWORD=change-me     # ОБЯЗАТЕЛЬНО сменить в проде

# --- Уведомления менеджеру / watchdog ---
ALERT_WHATSAPP_TO=           # рабочий номер, куда падают алерты «клиент ждёт человека»
ALERT_BOT_ID=
ALERT_SILENCE_MINUTES=30
ALERT_AWAITING_MINUTES=10

# --- Поведение ---
DEBOUNCE_SECONDS=8
FOLLOWUP_ENABLED=true
FOLLOWUP_AFTER_HOURS=24      # автодожим долго думающих
FOLLOWUP_QUIET_FROM=22
FOLLOWUP_QUIET_TO=9

# --- Telegram (опционально, только для тестовой песочницы без WhatsApp) ---
# TELEGRAM_BOTS=[{"id":"college_test","scenario":"admission","title":"Колледж (тест)","token":""}]
